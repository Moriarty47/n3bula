{
  "name": "@n3bula/sandbox",
  "version": "0.0.1-alpha.3",
  "description": "Simple Sandbox for Node.js module quick test",
  "type": "module",
  "scripts": {
    "dev": "pnpm -C=example dev",
    "build": "tsdown"
  },
  "keywords": [
    "sandbox",
    "node"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./types": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "contributors": [
    {
      "name": "Moriarty47",
      "email": "wang_jn_xian@163.com"
    }
  ],
  "homepage": "https://github.com/Moriarty47/n3bula/tree/main/packages/sandbox#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moriarty47/n3bula.git",
    "directory": "packages/sandbox"
  },
  "author": {
    "name": "Moriarty47",
    "email": "wang_jn_xian@163.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.5"
  },
  "dependencies": {
    "@n3bula/echo": "workspace:^",
    "esbuild": "^0.25.12"
  },
  "sideEffects": false
}
