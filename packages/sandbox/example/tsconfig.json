{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "es2022",
    "types": ["node", "@n3bula/sandbox/types"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "esModuleInterop": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["*.ts"]
}
