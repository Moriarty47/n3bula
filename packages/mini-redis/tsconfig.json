{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "types": ["node"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "$const": ["./src/util/constants.ts"],
      "$main/*": ["./src/main/*"],
      "$util/*": ["./src/util/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "nova.config.ts"]
}
