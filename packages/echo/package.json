{
  "name": "@n3bula/echo",
  "version": "0.2.0-alpha.1",
  "description": "Colorized log",
  "type": "module",
  "main": "./dist/browser/index.js",
  "types": "./dist/browser/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "require": "./dist/browser/index.umd.js",
      "default": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.mts",
      "import": "./dist/node/index.mjs",
      "require": "./dist/node/index.cjs",
      "default": "./dist/node/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "log",
    "colorized",
    "echo",
    "n3bula"
  ],
  "scripts": {
    "dev": "cross-env MODE=dev tsdown --watch",
    "dev:node": "cross-env MODE=dev ENV=node tsdown --watch",
    "dev:browser": "cross-env MODE=dev ENV=browser tsdown --watch",
    "build": "cross-env MODE=prod tsdown"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "contributors": [
    {
      "name": "Moriarty47",
      "email": "wang_jn_xian@163.com"
    }
  ],
  "homepage": "https://github.com/Moriarty47/n3bula/tree/main/packages/echo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Moriarty47/n3bula.git",
    "directory": "packages/echo"
  },
  "author": {
    "name": "Moriarty47",
    "email": "wang_jn_xian@163.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}